MissionRuntime.Tick(deltaTime) {
    _elapsedTime += deltaTime;

    // 1. 评估所有目标
    foreach (objective in _objectives) {
        var progress = _evaluators[objective.Type].Evaluate(objective, _registry);
        if (progress != objective.LastProgress) {
            objective.LastProgress = progress;
            _eventBus.Publish(new MissionObjectiveUpdatedEvent(objective.Id, progress));
        }
    }

    // 2. 检查胜负条件
    var outcome = EvaluateOutcome();
    if (outcome != MissionOutcome.InProgress) {
        _eventBus.Publish(new BattleEndedEvent(BuildResult()));
    }
}

MissionOutcome EvaluateOutcome() {
    // 胜利检查
    bool victory = VictoryCondition switch {
        AllObjectives => _objectives.Where(o => !o.IsOptional).All(o => o.IsCompleted),
        AnyObjective => _objectives.Any(o => o.IsCompleted),
    };
    if (victory) return Victory;

    // 失败检查
    bool defeat = DefeatCondition switch {
        AllUnitsDead => PlayerFactionLivingCount == 0,
        TimeOut => _elapsedTime > TimeLimitSeconds,
    };
    if (defeat) return Defeat;

    return InProgress;
}
```

