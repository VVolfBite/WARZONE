### 23.2 伤害计算公式

```
float CalculateDamage(WeaponDefinition weapon, ArmorComponent armor, RNG rng) {
    // Step 1: 基础伤害
    float baseDamage = weapon.DamagePerHit;

    // Step 2: 护甲克制
    float armorMultiplier = DamageTable.GetMultiplier(weapon.DamageType, armor.ArmorType);
    float afterArmor = baseDamage * armorMultiplier;

    // Step 3: 护甲值减免（可选，取决于设计偏好）
    // 方案 A：固定减免 → finalDamage = max(1, afterArmor - armor.ArmorValue)
    // 方案 B：百分比减免 → finalDamage = afterArmor * (1 - armor.ArmorValue / (armor.ArmorValue + 100))
    float afterReduction = ApplyArmorReduction(afterArmor, armor.ArmorValue);

    // Step 4: 暴击（可选）
    if (rng.NextFloat() < critChance)
        afterReduction *= critMultiplier;

    // Step 5: 最小伤害保底
    return max(1, afterReduction);
}
```

### 23.3 溅射伤害

```
void ApplySplashDamage(DamageEvent primaryEvent, IEntityRegistry registry) {
    if (weapon.SplashRadius <= 0) return;

    var nearby = registry.QueryInRadius(
        primaryEvent.HitPosition, weapon.SplashRadius,
        typeof(HealthComponent), typeof(FactionComponent));

    foreach (var entity in nearby) {
        if (entity.Id == primaryEvent.TargetEntityId) continue;  // 主目标已处理
        float distance = Vector2.Distance(entity.Position, primaryEvent.HitPosition);
        float falloff = 1f - (distance / weapon.SplashRadius) * weapon.SplashFalloff;
        float splashDamage = primaryEvent.FinalDamage * max(0, falloff);
        ApplyDamageToEntity(entity, splashDamage, ...);
    }
}
```

### 23.4 攻击流程

```
CombatSystem.Tick(deltaTime) {
    foreach (entity with WeaponComponent + TargetingComponent) {
        // 1. 检查冷却
        if (weapon.CooldownRemaining > 0) {
            weapon.CooldownRemaining -= deltaTime;
            continue;
        }

        // 2. 获取目标
        var target = targeting.CurrentTargetId;
        if (target == null) {
            if (targeting.AutoAcquire) target = FindNearestEnemy(entity);
            else continue;
