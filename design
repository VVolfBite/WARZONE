ContentValidator {
    ValidationResult Validate(ContentCatalog catalog) {
        var errors = new List<string>();

        // 引用完整性
        foreach (unit in catalog.Units.Values) {
            if (!catalog.Weapons.ContainsKey(unit.WeaponId))
                errors.Add($"Unit '{unit.Id}' references missing weapon '{unit.WeaponId}'");
        }
        foreach (mission in catalog.Missions.Values) {
            foreach (var squad in mission.StartingSquads) {
                if (!catalog.Units.ContainsKey(squad.UnitDefinitionId))
                    errors.Add($"Mission '{mission.Id}' references missing unit '{squad.UnitDefinitionId}'");
            }
        }

        // 数值合理性
        foreach (unit in catalog.Units.Values) {
            if (unit.MaxHealth <= 0) errors.Add($"Unit '{unit.Id}' has MaxHealth <= 0");
            if (unit.MoveSpeed < 0) errors.Add($"Unit '{unit.Id}' has negative MoveSpeed");
        }
        foreach (weapon in catalog.Weapons.Values) {
            if (weapon.DamagePerHit <= 0) errors.Add($"Weapon '{weapon.Id}' has DamagePerHit <= 0");
            if (weapon.Range <= 0) errors.Add($"Weapon '{weapon.Id}' has Range <= 0");
            if (weapon.AttackInterval <= 0) errors.Add($"Weapon '{weapon.Id}' has AttackInterval <= 0");
        }

        return new ValidationResult(errors);
    }
}
