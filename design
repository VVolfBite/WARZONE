AbilitySystem {
    void TryUseAbility(EntityId sourceId, string abilityId, Vector2? targetPos, EntityId? targetEntity) {
        var ability = _catalog.Abilities[abilityId];
        var cooldown = _cooldowns.GetRemaining(sourceId, abilityId);

        // 1. 检查冷却
        if (cooldown > 0) return;

        // 2. 检查条件
        if (!ValidateConditions(sourceId, ability)) return;

        // 3. 检查距离
        if (ability.Range.HasValue) {
            float dist = Distance(sourceId.Position, targetPos ?? targetEntity.Position);
            if (dist > ability.Range.Value) return;
        }

        // 4. 施法前摇
        if (ability.CastTime > 0) {
            _pendingCasts.Add(new PendingCast(sourceId, ability, targetPos, targetEntity, ability.CastTime));
            return;
        }

        // 5. 应用效果
        ApplyEffects(sourceId, ability, targetPos, targetEntity);

        // 6. 进入冷却
        _cooldowns.SetCooldown(sourceId, abilityId, ability.CooldownSeconds);
    }
}
