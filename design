## 24. 移动与寻路系统（Movement & Pathfinding）

### 24.1 移动系统

```
MovementSystem.Tick(deltaTime) {
    foreach (entity with MovementComponent + PositionComponent) {
        if (!movement.IsMoving) continue;

        // 1. 计算方向
        Vector2 direction = (targetPosition - position.Position);
        float distance = direction.Length();

        // 2. 到达判定
        if (distance < ArrivalThreshold) {
            position.Position = targetPosition;
            movement.IsMoving = false;
            continue;
        }

        // 3. 加速度模型
        direction = direction.Normalized();
        float currentSpeed = movement.CurrentSpeed;
        float targetSpeed = movement.MoveSpeed;

        if (currentSpeed < targetSpeed)
            currentSpeed = min(currentSpeed + movement.Acceleration * deltaTime, targetSpeed);

        // 4. 转向（可选）
        float targetAngle = atan2(direction.Y, direction.X);
        position.Rotation = LerpAngle(position.Rotation, targetAngle, movement.TurnSpeed * deltaTime);

        // 5. 移动
        float step = currentSpeed * deltaTime;
        if (step >= distance) {
            position.Position = targetPosition;
            movement.IsMoving = false;
        } else {
            position.Position += direction * step;
        }
    }
}
```

### 24.2 碰撞分离

```
CollisionSystem.Tick() {
    // 实体间碰撞
    for (int i = 0; i < entities.Count; i++) {
        for (int j = i + 1; j < entities.Count; j++) {
            float minDist = collision[i].Radius + collision[j].Radius;
            Vector2 offset = pos[j] - pos[i];
            float dist = offset.Length();
            if (dist >= minDist || dist < 0.0001f) continue;

            Vector2 dir = offset.Normalized();
            float penetration = minDist - dist;
            // 按移动状态分配推开比例
            float ratioA = movement[i].IsMoving ? 0.3f : 0.7f;
            float ratioB = 1f - ratioA;
            pos[i] -= dir * (penetration * ratioA);
            pos[j] += dir * (penetration * ratioB);
        }
    }

    // 障碍物碰撞（通过 Unity NavMesh 或 ObstacleVolume）
    foreach (entity with CollisionComponent) {
        ResolveObstacleOverlap(entity);
    }
}
