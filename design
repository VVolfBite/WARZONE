### 25.1 行为树框架

```
// 节点基类
abstract class BehaviorNode {
    enum Status { Success, Failure, Running }
    abstract Status Tick(AIBlackboard blackboard, float deltaTime);
    virtual void OnEnter(AIBlackboard bb) { }
    virtual void OnExit(AIBlackboard bb) { }
}

// 复合节点
class Selector : BehaviorNode {            // 选择第一个成功的子
    List<BehaviorNode> Children;
    Status Tick(bb, dt) {
        foreach (child in Children)
            if (child.Tick(bb, dt) != Failure) return Running/Success;
        return Failure;
    }
}

class Sequence : BehaviorNode {            // 按顺序执行，任一失败则失败
    List<BehaviorNode> Children;
    Status Tick(bb, dt) {
        foreach (child in Children)
            if (child.Tick(bb, dt) != Success) return Running/Failure;
        return Success;
    }
}

// 装饰节点
class Repeat : BehaviorNode {              // 重复执行子节点
    BehaviorNode Child;
    int RepeatCount;                       // -1 = 无限
}

class Inverter : BehaviorNode {            // 反转子节点结果
    BehaviorNode Child;
}

// 叶节点
class Condition : BehaviorNode {           // 条件判断
    Func<AIBlackboard, bool> Predicate;
}

class Action : BehaviorNode {              // 执行动作
    Func<AIBlackboard, float, Status> Execute;
}
