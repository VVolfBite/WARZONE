        // 3. 检查距离
        float distance = Vector2.Distance(entity.Position, target.Position);
        if (distance > weapon.Range) continue;  // 移动系统会靠近

        // 4. 执行攻击
        var damageEvent = CalculateAndApplyDamage(entity, target);
        eventBus.Publish(new DamageDealtEvent(damageEvent));

        // 5. 生成投射物（如果有）
        if (weapon.ProjectileSpeed > 0)
            SpawnProjectile(entity, target, weapon);

        // 6. 重置冷却
        weapon.CooldownRemaining = weapon.AttackInterval;
    }
}
